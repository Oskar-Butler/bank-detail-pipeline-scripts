# Cloud Run Job: Gemini OCR worker
# Copy to .env and fill in real values before local testing.

# --- Required ---
OCR_PROJECT_ID=your-gcp-project
OCR_INPUT_GCS_PATH=gs://your-landing-bucket/ocr_input/current.csv
OCR_EXPORT_BUCKET_NAME=your-landing-bucket

# --- Optional (defaults shown) ---
OCR_EXPORT_PREFIX=ocr_output
OCR_LOCATION=us-central1
OCR_GEMINI_MODEL=gemini-2.5-pro
OCR_SHARD_COUNT=5
OCR_MAX_PDF_PAGES=10
OCR_MIN_IMAGE_WIDTH=400
OCR_MIN_IMAGE_HEIGHT=400
OCR_GEMINI_RETRIES=6
OCR_GEMINI_DELAY=5.0
OCR_GEMINI_CONCURRENT_LIMIT=2
OCR_GEMINI_RPM_LIMIT=12
OCR_GEMINI_TIMEOUT=120.0
OCR_MAX_INPUT_SIZE=52428800
OCR_MAX_INPUT_ROWS=10000

# Set by Cloud Run when running as a Job; leave unset locally
# CLOUD_RUN_TASK_INDEX=0
