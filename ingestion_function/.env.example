# Cloud Function: Drive → GCS ingestion
# Copy to .env and fill in real values before local testing.

# --- Required ---
OCR_PROJECT_ID=your-gcp-project
OCR_GCS_BUCKET_NAME=your-landing-bucket
OCR_DRIVE_DROPOFF_FOLDER_ID=your-drive-dropoff-folder-id
OCR_DRIVE_ARCHIVE_FOLDER_ID=your-drive-archive-folder-id

# --- Optional (defaults shown) ---
OCR_FIRESTORE_DATABASE_ID=(default)
OCR_FIRESTORE_COLLECTION=processed_urls
OCR_GCS_OUTPUT_BLOB=ocr_input/current.csv
OCR_MAX_DRIVE_FILE_BYTES=52428800
